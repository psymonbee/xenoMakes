# Stuff that should NEVER go into git.

# Downloaded dependencies. These are fetched by "npm install" on each computer,
# so we don't store them here (there can be thousands of files!).
node_modules/

# Machine-specific editor settings and noise.
.claude/settings.local.json
.DS_Store
*.log

# The shared levels + accounts database (lives on the server, never in git).
data/

# The "drop zone" for new art packs you're importing. You put a freshly
# downloaded Kenney pack in here and run /addpacks; the skill copies the art
# into assets/packs/ properly and then EMPTIES this folder, so nothing raw is
# ever committed and you never end up with a duplicate copy sitting around.
incoming-packs/
